{
  "name": "anypeek",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "node ./scripts/clean.mjs",
    "dev": "vite",
    "dev:web": "vite",
    "dev:cf": "wrangler dev --config wrangler.jsonc",
    "dev:proxy": "tsx server/index.ts",
    "build": "node ./scripts/clean.mjs && tsc -p tsconfig.cloudflare.json --noEmit && tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:cf": "tsc -p tsconfig.cloudflare.json --noEmit",
    "check:deno": "deno check --config deno.json deno.server.ts",
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "deploy:cf": "pnpm run build && wrangler deploy --config wrangler.jsonc",
    "deploy:deno": "pnpm run build && deno deploy --config deno.json --prod .",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@js-preview/docx": "^1.6.4",
    "@js-preview/excel": "^1.7.14",
    "@tanstack/react-virtual": "^3.13.21",
    "@tauri-apps/api": "^2.10.1",
    "core-js": "^3.48.0",
    "hono": "^4.12.7",
    "pptx-preview": "^1.0.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "2.0.7",
    "yet-another-react-lightbox": "^3.29.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.27.0",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.72.0"
  }
}
